# NextAuth
AUTH_SECRET=                    # openssl rand -base64 32 로 생성
NEXTAUTH_URL=http://localhost:3000

# Google OAuth (https://console.cloud.google.com)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Neon PostgreSQL (https://neon.tech)
DATABASE_URL=

# Finnhub - 미국 주식 (https://finnhub.io)
FINNHUB_API_KEY=

# Firebase Admin SDK - FCM 푸시 알림 (https://console.firebase.google.com)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=               # "-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n" 형식

# Firebase 클라이언트 SDK - FCM 수신용 (https://console.firebase.google.com > 프로젝트 설정 > 일반 > 내 앱)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_VAPID_KEY=             # Cloud Messaging > 웹 푸시 인증서

# Vercel Cron 보안 (임의 문자열)
CRON_SECRET=
